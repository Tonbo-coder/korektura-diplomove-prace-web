# SMTP – odesílání e-mailů (objednávky, hodnocení)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@korektura-diplomove-prace.cz
SMTP_PASS=your-smtp-password

# E-mailové adresy
EMAIL_FROM=info@korektura-diplomove-prace.cz
ORDER_TO_EMAIL=info@korektura-diplomove-prace.cz

# Vercel Blob – úložiště nahraných souborů
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# Zabezpečení cron jobu /api/cron/cleanup-blobs (nastavte i ve Vercelu)
CRON_SECRET=nahodny-dlouhy-retezec
